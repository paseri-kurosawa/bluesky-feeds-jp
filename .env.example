# Bluesky Credentials (stored in AWS Secrets Manager)
# NOTE: アプリパスワードは再発行できません。以下のコマンドで AWS Secrets Manager に登録してください:
# aws secretsmanager create-secret --name bluesky-feed-jp/credentials \
#   --secret-string '{"handle":"your-handle.bsky.social","appPassword":"your-app-password"}'
# BSKY_HANDLE=example.bsky.social (stored in Secrets Manager, not in .env)
# BSKY_APP_PASSWORD=<stored in Secrets Manager, not in .env>

# AWS Configuration
CDK_DEFAULT_ACCOUNT=878311109818
CDK_DEFAULT_REGION=ap-northeast-1

# Feed Configuration
# NOTE: これらはCDKデプロイ後に更新してください
FEED_DID=did:web:<api-endpoint>
SERVICE_ENDPOINT=https://<api-endpoint>

# Density Filtering
DENSITY_THRESHOLD=2.0

# Valkey (デプロイ後に自動設定)
VALKEY_ENDPOINT=<set-after-deployment>
